set cell_name   "or2"set corner_name "sl_1v2_hvt"set_db init_lib_search_path "../../../gpdk045_lib"set_db init_hdl_search_path "../../00_src"set lib_file "slow_vdd1v2_basicCells_hvt.lib"read_libs $lib_fileread_hdl  -sv ${cell_name}.svelaborate ${cell_name}set_db syn_generic_effort mediumset_db syn_map_effort      mediumsyn_genericsyn_mapset rpt_dir "../../02_reports/${cell_name}/${corner_name}"file mkdir $rpt_dirreport_area   > "${rpt_dir}/area.rpt"report_power  > "${rpt_dir}/power.rpt"report_timing > "${rpt_dir}/timing.rpt"report_qor    > "${rpt_dir}/qor.rpt"set out_dir "../../03_outputs/${cell_name}/${corner_name}"file mkdir $out_dirwrite_hdl > "${out_dir}/${cell_name}_netlist.sv"write_sdf -version 2.1 -timescale ns > "${out_dir}/delay.sdf"puts "Done synthesis for ${cell_name} at ${corner_name}"exit